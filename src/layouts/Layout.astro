---
import { SITE, meta, faqItems, type Lang } from '../i18n/ui';
import '../styles/global.css';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const m = meta[lang];

const canonical = `${SITE}${lang === 'es' ? '/' : '/en/'}`;

const faqSchema = faqItems(lang).map((item) => ({
  '@type': 'Question',
  name: item.q,
  acceptedAnswer: { '@type': 'Answer', text: item.a },
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${SITE}/#laura`,
      name: 'Laura Araúz',
      alternateName: 'Lala',
      jobTitle: 'Nutricionista Dietista',
      image: `${SITE}/assets/laura.png`,
      url: `${SITE}/`,
      sameAs: ['https://www.instagram.com/lalanutricion', 'https://www.tiktok.com/@lalanutricion'],
      hasCredential: 'Reg. 1366',
      worksFor: { '@id': `${SITE}/#business` },
    },
    {
      '@type': ['LocalBusiness', 'MedicalBusiness'],
      '@id': `${SITE}/#business`,
      name: 'Lala Nutrición',
      alternateName: 'Laura Araúz · Nutricionista Dietista',
      image: `${SITE}/assets/logo.png`,
      logo: `${SITE}/assets/logo.png`,
      url: `${SITE}/`,
      telephone: '+507-6412-3914',
      email: 'soy@lalanutricion.com',
      priceRange: '$$',
      medicalSpecialty: 'Nutrition',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Clínica Mollin, PH Dominó',
        addressLocality: 'Ciudad de Panamá',
        addressCountry: 'PA',
      },
      areaServed: { '@type': 'City', name: 'Ciudad de Panamá' },
      availableLanguage: ['Spanish', 'English'],
      founder: { '@id': `${SITE}/#laura` },
    },
    {
      '@type': 'WebSite',
      url: `${SITE}/`,
      name: 'Lala Nutrición',
      inLanguage: ['es-PA', 'en'],
      publisher: { '@id': `${SITE}/#business` },
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonical}#faq`,
      inLanguage: lang === 'es' ? 'es-PA' : 'en',
      mainEntity: faqSchema,
    },
  ],
};
---

<!DOCTYPE html>
<html lang={m.htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#5C6438" />
  <meta name="color-scheme" content="light" />

  <title>{m.title}</title>
  <meta name="description" content={m.description} />
  <meta name="keywords" content={m.keywords} />
  <meta name="author" content="Laura Araúz" />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="googlebot" content="index, follow" />
  <meta name="geo.region" content="PA-8" />
  <meta name="geo.placename" content="Ciudad de Panamá" />

  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="es" href={`${SITE}/`} />
  <link rel="alternate" hreflang="en" href={`${SITE}/en/`} />
  <link rel="alternate" hreflang="x-default" href={`${SITE}/`} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <link rel="icon" type="image/png" href="/assets/1-crop.png" />
  <link rel="apple-touch-icon" href="/assets/1-crop.png" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={m.ogTitle} />
  <meta property="og:description" content={m.ogDescription} />
  <meta property="og:image" content={`${SITE}/assets/logo.png`} />
  <meta property="og:image:alt" content="Laura Araúz · Nutricionista Dietista" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Lala Nutrición" />
  <meta property="og:locale" content={m.ogLocale} />
  <meta property="og:locale:alternate" content={m.ogLocaleAlt} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={m.twTitle} />
  <meta name="twitter:description" content={m.twDescription} />
  <meta name="twitter:image" content={`${SITE}/assets/logo.png`} />
  <meta name="twitter:image:alt" content="Laura Araúz · Nutricionista Dietista" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />

  <!-- Schema.org structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>

<body>
  <slot />
</body>
</html>
