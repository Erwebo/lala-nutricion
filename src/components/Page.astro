---
import { Image } from 'astro:assets';
import { useTranslations, waLink, type Lang } from '../i18n/ui';

import logoCrop from '../assets/2-crop.png';
import hero1 from '../assets/hero1.png';
import hero2 from '../assets/hero2.png';
import lauraImg from '../assets/laura.png';
import insta1 from '../assets/insta1.jpg';
import insta2 from '../assets/insta2.jpg';
import insta3 from '../assets/insta3.jpg';
import insta4 from '../assets/insta4.jpg';
import problema1 from '../assets/problema1.png';
import problema2 from '../assets/problema2.png';
import problema3 from '../assets/problema3.png';
import problema4 from '../assets/problema4.png';
import problema5 from '../assets/problema5.png';
import problema6 from '../assets/problema6.png';
import ing1 from '../assets/1ing.png';
import ing2 from '../assets/2ing.png';
import ing3 from '../assets/3ing.png';
import ing4 from '../assets/4ing.png';
import ing5 from '../assets/5ing.png';
import ing6 from '../assets/6ing.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const altHref = lang === 'es' ? '/en/' : '/';
const toggleLabel = lang === 'es' ? 'EN' : 'ES';

// Las tarjetas de "problemas" usan distinta imagen por idioma (texto incrustado).
const probImgs = lang === 'es'
  ? [problema1, problema2, problema3, problema4, problema5, problema6]
  : [ing1, ing4, ing2, ing5, ing6, ing3];

const instaImgs = [insta1, insta2, insta3, insta4];
const instaAlts = [
  'Laura Araúz en conferencia de nutrición',
  'Nutrifacto del día por Laura Araúz',
  'Contenido de bienestar y nutrición',
  'Educación nutricional con Lala',
];
---

<a href="#main" class="skip-link">{t('skip')}</a>

<div class="scroll-progress" id="scrollProgress" aria-hidden="true"></div>

<!-- MOBILE MENU -->
<nav class="mobile-nav" id="mobileNav" aria-label="Menú móvil">
  <button class="mobile-close" id="mobileClose" aria-label="Cerrar menú">✕</button>
  <a href="#sobre">{t('nav.sobre')}</a>
  <a href="#proceso">{t('nav.proceso')}</a>
  <a href="#planes">{t('nav.planes')}</a>
  <a href="#testimonios">{t('nav.testimonios')}</a>
  <a href="#faq">{t('nav.faq')}</a>
  <a href="#contacto">{t('nav.contacto')}</a>
  <a class="lang-btn" href={altHref} style="font-size:1rem;padding:8px 18px;margin-top:4px;" aria-label="Cambiar idioma / Switch language">{toggleLabel}</a>
  <a href={waLink(lang, 'caso')} target="_blank" rel="noopener" class="btn btn-olive" style="margin-top:8px;">{t('nav.cta')}</a>
</nav>

<!-- NAV -->
<header id="nav">
  <div class="container">
    <div class="nav-inner">
      <a href="#hero" class="nav-logo" aria-label="Inicio · Lala Nutrición">
        <Image src={logoCrop} alt="Laura Araúz · Nutricionista Dietista" class="nav-logo-icon" />
      </a>
      <ul class="nav-links">
        <li><a href="#sobre">{t('nav.sobre')}</a></li>
        <li><a href="#proceso">{t('nav.proceso')}</a></li>
        <li><a href="#planes">{t('nav.planes')}</a></li>
        <li><a href="#faq">{t('nav.faq')}</a></li>
        <li><a href="#contacto">{t('nav.contacto')}</a></li>
      </ul>
      <a class="lang-btn" href={altHref} aria-label="Cambiar idioma / Switch language">{toggleLabel}</a>
      <a href={waLink(lang, 'caso')} target="_blank" rel="noopener" class="btn btn-olive nav-cta desk">{t('nav.cta')}</a>
      <button class="hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<main id="main">

<!-- HERO -->
<section id="hero" aria-label="Presentación">

  <article class="hero-slide active" aria-hidden="false">
    <div class="h-img-col">
      <Image src={hero1} alt="Laura Araúz, Nutricionista Dietista, en consulta" loading="eager" fetchpriority="high" />
    </div>
    <div class="h-text-col">
      <div class="h-text-inner">
        <div class="h-tag">{t('h1.tag')}</div>
        <h1 class="h-title" set:html={t('h1.title')}></h1>
        <span class="h-sub">{t('h1.sub')}</span>
        <p class="h-desc">{t('h1.desc')}</p>
        <div class="h-btns">
          <a href={waLink(lang, 'caso')} target="_blank" rel="noopener" class="btn btn-olive">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            <span>{t('h1.cta1')}</span>
          </a>
          <a href="#planes" class="btn btn-outline-olive">{t('h1.cta2')}</a>
        </div>
      </div>
    </div>
  </article>

  <article class="hero-slide" aria-hidden="true">
    <div class="h-img-col">
      <Image src={hero2} alt="Laura Araúz · Nutrición Sostenible" loading="lazy" />
    </div>
    <div class="h-text-col">
      <div class="h-text-inner">
        <div class="h-tag">{t('h2s.tag')}</div>
        <h1 class="h-title" set:html={t('h2s.title')}></h1>
        <p class="h-desc">{t('h2s.desc')}</p>
        <div class="h-btns">
          <a href={waLink(lang, 'caso')} target="_blank" rel="noopener" class="btn btn-olive">{t('h1.cta1')}</a>
          <a href="#sobre" class="btn btn-outline-olive">{t('h2s.cta2')}</a>
        </div>
      </div>
    </div>
  </article>

  <div class="hero-dots" role="tablist" aria-label="Slides del hero">
    <button class="hero-dot active" data-slide="0" aria-label="Slide 1"></button>
    <button class="hero-dot" data-slide="1" aria-label="Slide 2"></button>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- PROBLEMAS -->
<section id="problemas" aria-labelledby="problemas-h">
  <div class="container">
    <div class="problemas-header reveal">
      <span class="label">{t('prob.label')}</span>
      <h2 id="problemas-h">{t('prob.h2')}</h2>
      <p>{t('prob.p')}</p>
    </div>
    <div class="problemas-grid">
      {probImgs.map((img, i) => (
        <figure class={`problema-card reveal d${i + 1}`}>
          <Image src={img} alt={t(`prob.alt${i + 1}`)} loading="lazy" />
        </figure>
      ))}
    </div>
    <div class="problemas-cta reveal">
      <a href={waLink(lang, 'entender')} target="_blank" rel="noopener" class="btn btn-olive">{t('prob.cta')}</a>
    </div>
  </div>
</section>

<!-- SOBRE LAURA -->
<section id="sobre" aria-labelledby="sobre-h">
  <div class="container">
    <div class="sobre-grid">
      <div class="sobre-img-wrap reveal-left">
        <Image src={lauraImg} alt="Laura Araúz · Nutricionista Dietista Reg. 1366" loading="lazy" />
        <div class="sobre-badge">
          <strong>Laura Araúz</strong>
          <span>{t('sobre.credential')}</span>
        </div>
      </div>
      <div class="sobre-text reveal-right">
        <span class="label">{t('sobre.label')}</span>
        <h2 id="sobre-h">{t('sobre.h2')}</h2>
        <p>{t('sobre.p1')}</p>
        <p>{t('sobre.p2')}</p>
        <p>{t('sobre.p3')}</p>
        <div class="sobre-pills">
          <span class="pill">{t('sobre.pill1')}</span>
          <span class="pill">{t('sobre.pill2')}</span>
          <span class="pill">{t('sobre.pill3')}</span>
          <span class="pill">{t('sobre.pill4')}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PROCESO -->
<section id="proceso" aria-labelledby="proceso-h">
  <div class="container">
    <div class="proceso-header reveal">
      <h2 id="proceso-h">{t('proc.h2')}</h2>
      <p>{t('proc.p')}</p>
    </div>
    <ol class="proceso-steps" style="list-style:none;">
      <li class="step reveal d1">
        <span class="step-num" aria-hidden="true">01</span>
        <h3>{t('proc.s1h')}</h3>
        <p>{t('proc.s1p')}</p>
      </li>
      <li class="step reveal d2">
        <span class="step-num" aria-hidden="true">02</span>
        <h3>{t('proc.s2h')}</h3>
        <p>{t('proc.s2p')}</p>
      </li>
      <li class="step reveal d3">
        <span class="step-num" aria-hidden="true">03</span>
        <h3>{t('proc.s3h')}</h3>
        <p>{t('proc.s3p')}</p>
      </li>
    </ol>
    <p class="proceso-lema reveal">{t('proc.lema')}</p>
  </div>
</section>

<!-- PLANES -->
<section id="planes" aria-labelledby="planes-h">
  <div class="container">
    <div class="planes-header reveal">
      <span class="label">{t('plan.label')}</span>
      <h2 id="planes-h">{t('plan.h2')}</h2>
      <p>{t('plan.p')}</p>
    </div>
    <div class="planes-grid">

      <article class="plan reveal d1">
        <div class="plan-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2M9 12h6M9 16h4"/></svg>
        </div>
        <h3>{t('plan1.h')}</h3>
        <p>{t('plan1.p')}</p>
        <a href={waLink(lang, 'primera')} target="_blank" rel="noopener" class="plan-link">{t('plan1.a')}</a>
      </article>

      <article class="plan reveal d2">
        <div class="plan-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <h3>{t('plan2.h')}</h3>
        <p>{t('plan2.p')}</p>
        <a href={waLink(lang, 'pareja')} target="_blank" rel="noopener" class="plan-link">{t('plan2.a')}</a>
      </article>

      <article class="plan featured reveal d3">
        <span class="plan-rec">{t('plan3.rec')}</span>
        <div class="plan-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </div>
        <h3>{t('plan3.h')}</h3>
        <p>{t('plan3.p')}</p>
        <a href={waLink(lang, 'programa')} target="_blank" rel="noopener" class="plan-link">{t('plan3.a')}</a>
      </article>

    </div>
    <div style="text-align:center; margin-top:48px;" class="reveal">
      <p style="color:var(--text-light); font-size:0.85rem; font-style:italic; margin-bottom:4px;">{t('plan.note1')}</p>
      <p style="color:var(--text-light); font-size:0.88rem; margin-bottom:20px;">{t('plan.note2')}</p>
      <a href={waLink(lang, 'caso')} target="_blank" rel="noopener" class="btn btn-olive">{t('plan.cta')}</a>
    </div>
  </div>
</section>

<!-- EMPIEZA TU PROCESO -->
<section id="empieza" aria-labelledby="empieza-h">
  <div class="container">
    <div class="empieza-center reveal">
      <span class="label" style="color:var(--olive-pale);">{t('emp.label')}</span>
      <h2 id="empieza-h">{t('emp.h2')}</h2>
      <span class="italic-sub">{t('emp.sub')}</span>
      <div class="empieza-divider"></div>
      <p>{t('emp.p')}</p>
      <a href={waLink(lang, 'evaluacion')} target="_blank" rel="noopener" class="btn btn-olive" style="font-size:0.9rem;padding:15px 36px;letter-spacing:0.07em;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="white" style="flex-shrink:0;" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        <span>{t('emp.cta')}</span>
      </a>
      <p class="note">{t('emp.note')}</p>
    </div>
  </div>
</section>

<!-- INSTAGRAM -->
<section id="instagram" aria-labelledby="insta-h">
  <div class="container">
    <div class="insta-header reveal">
      <span class="label">Instagram</span>
      <h2 id="insta-h">{t('insta.h2')}</h2>
      <a href="https://www.instagram.com/lalanutricion" target="_blank" rel="noopener" class="insta-handle">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        @lalanutricion
      </a>
      <p>{t('insta.p')}</p>
    </div>

    <div class="insta-grid">
      {instaImgs.map((img, i) => (
        <a href="https://www.instagram.com/lalanutricion" target="_blank" rel="noopener" class={`insta-item reveal d${i + 1}`} aria-label="Instagram @lalanutricion">
          <Image src={img} alt={instaAlts[i]} loading="lazy" />
          <div class="insta-overlay"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></div>
        </a>
      ))}
    </div>

    <div class="insta-footer reveal">
      <a href="https://www.instagram.com/lalanutricion" target="_blank" rel="noopener" class="btn btn-outline-olive">{t('insta.btn')}</a>
    </div>
  </div>
</section>

<!-- TESTIMONIOS -->
<section id="testimonios" aria-labelledby="testi-h">
  <div class="container">
    <div class="testi-header reveal">
      <span class="label">{t('testi.label')}</span>
      <h2 id="testi-h">{t('testi.h2')}</h2>
    </div>
    <div class="testi-grid">
      <figure class="testi-card reveal d1">
        <span class="quote" aria-hidden="true">"</span>
        <blockquote class="testi-text">{t('testi.t1')}</blockquote>
        <figcaption class="testi-author">
          <div class="avatar" aria-hidden="true">C</div>
          <div><div class="author-name">Cesar</div><div class="stars" aria-label="5 estrellas">★★★★★</div></div>
        </figcaption>
      </figure>
      <figure class="testi-card reveal d2">
        <span class="quote" aria-hidden="true">"</span>
        <blockquote class="testi-text">{t('testi.t2')}</blockquote>
        <figcaption class="testi-author">
          <div class="avatar" aria-hidden="true">M</div>
          <div><div class="author-name">Maria</div><div class="stars" aria-label="5 estrellas">★★★★★</div></div>
        </figcaption>
      </figure>
      <figure class="testi-card reveal d3">
        <span class="quote" aria-hidden="true">"</span>
        <blockquote class="testi-text">{t('testi.t3')}</blockquote>
        <figcaption class="testi-author">
          <div class="avatar" aria-hidden="true">C</div>
          <div><div class="author-name">Carla</div><div class="stars" aria-label="5 estrellas">★★★★★</div></div>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<!-- FAQ -->
<section id="faq" aria-labelledby="faq-h">
  <div class="container">
    <div class="faq-header reveal">
      <span class="label">{t('faq.label')}</span>
      <h2 id="faq-h">{t('faq.h2')}</h2>
      <p>{t('faq.p')}</p>
    </div>
    <div class="faq-list">
      {[1, 2, 3, 4, 5, 6].map((n) => (
        <details class="faq-item reveal">
          <summary class="faq-q">
            <span>{t(`faq.q${n}`)}</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-a">{t(`faq.a${n}`)}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- CONTACTO -->
<section id="contacto" aria-labelledby="cont-h">
  <div class="container">
    <div class="contacto-hd reveal" style="text-align:center;max-width:600px;margin:0 auto 64px;">
      <span class="label">{t('nav.contacto')}</span>
      <h2 id="cont-h">{t('cont.h2')}</h2>
      <p>{t('cont.p')}</p>
    </div>

    <div class="c-row reveal">
      <div class="c-card">
        <div class="c-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 01.1 2.18 2 2 0 012.07 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        </div>
        <div class="c-label">WhatsApp</div>
        <div class="c-value"><a href="https://wa.me/50764123914" target="_blank" rel="noopener">(+507) 6412-3914</a></div>
      </div>
      <div class="c-card">
        <div class="c-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div class="c-label">Email</div>
        <div class="c-value"><a href="mailto:soy@lalanutricion.com">soy@lalanutricion.com</a></div>
      </div>
      <div class="c-card">
        <div class="c-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div class="c-label">{t('cont.pres')}</div>
        <div class="c-value">Clínica Mollin, Ph Dominó<br>Ciudad de Panamá</div>
      </div>
